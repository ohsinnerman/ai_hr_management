# ── NexusHR backend — PRODUCTION env (copy to .env on the EC2 box) ──
# Fill every value. NEVER commit the real .env.

NODE_ENV=production
PORT=5000

# The public URL of your deployed frontend (Vercel/Amplify/etc.)
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ORIGIN=https://your-frontend.vercel.app

# ── MongoDB Atlas (free M0) ──
# Atlas → Database → Connect → Drivers → copy the SRV string, add the DB name "nexushr".
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/nexushr?retryWrites=true&w=majority

# ── Upstash Redis (free) ──
# Upstash → your database → "Redis" connect → copy the rediss:// URL (TLS).
REDIS_URL=rediss://default:PASSWORD@your-db.upstash.io:6379

# ── JWT secrets — generate with: openssl rand -hex 32 ──
JWT_SECRET=replace_with_64_hex_chars
JWT_REFRESH_SECRET=replace_with_a_different_64_hex_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── PII encryption — exactly 32 chars. Generate: openssl rand -base64 24 | cut -c1-32 ──
# WARNING: changing this after data is saved makes encrypted PII unreadable.
ENCRYPTION_KEY=replace_with_32_character_string

# ── Cloudflare R2 (S3-compatible) ──
# R2 → Manage R2 API Tokens → create token; endpoint = https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_ACCESS_KEY=your_r2_access_key
S3_SECRET_KEY=your_r2_secret_key
S3_BUCKET=nexushr
S3_REGION=auto

# ── Google Gemini (AI Studio) — key starts with AIza... ──
GEMINI_API_KEY=AIzaSy_your_real_key_here
